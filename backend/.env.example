# Server
PORT=5000
NODE_ENV=development

# MongoDB (use Atlas connection string or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/travel_app?retryWrites=true&w=majority

# JWT Secret (used to sign and verify tokens)
JWT_SECRET=your_jwt_secret_key_here

# CORS (restrict to frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# External APIs
OPENWEATHER_API_KEY=your_openweathermap_api_key
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key
SERPAPI_KEY=your_serpapi_key
